herapy","image":"http://static1.squarespace.com/static/57f3065d1b631bd901f7661d/t/5ff8e9d093bc6a5d87dac56b/1610148309480/Banner.jpg?format=1500w","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Kohala Physical Therapy, Ultrasound Imaging, Sports injuries,  Orthopedic conditions, Post Surgical, Hand Therapy, Physical Therapy","location":"Hawi","rating":5,"lat":20.238238,"lng":-155.829559,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"2e042796-37cd-4667-ab82-97c6901771a5","name":"Helping You Get Back","title":"$undefined","businessName":"$undefined","image":"https://clubrehabhawaii.com/wp-content/uploads/2021/01/\u0010CR_Home_Ban_lift.jpg","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Life is too short and precious to struggle with physical pain and limitations. You deserve to participate in your life not sit on the sidelines. We help you find out what is causing the problem and help you fix it, so that you can get back to doing what you love — the things you were made to do.","location":"Kealakekua","rating":5,"lat":19.530888,"lng":-155.925801,"tier":"free","externalBookingUrl":"$undefined","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"7c71fc47-3f4e-4508-8353-5f6c67c21093","name":"Harvelee H. Leite - Ah Yo","title":"$undefined","businessName":"$undefined","image":"","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"","location":"Hilo","rating":5,"lat":19.724436,"lng":-155.090013,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"5d7bfb91-0da7-4635-9a64-62fbe5916dfc","name":"Tailored Therapy","title":"$undefined","businessName":"$undefined","image":"https://manaphysicaltherapy.com/wp-content/uploads/2024/09/Hero-Image.jpg","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Discover Therapy Solutions at Mana Physical Therapy. Achieve lasting relief and recovery today.","location":"Waikoloa","rating":5,"lat":19.927042,"lng":-155.787428,"tier":"free","externalBookingUrl":"$undefined","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"600a7a96-3a89-442c-813e-43e9796b7a5a","name":"Mission Statement","title":"$undefined","businessName":"$undefined","image":"","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Mauka Movement LLC is female owned and operated and welcomes the residents of South Kona and Ka’u for physical therapy services. As movement specialists, the physical therapists at Mauka Movement want to help our aging community continue to engage in their preferred activities. Mauka Movement addresses the complexities of the musculoskeletal and nervous systems. We educate our clientele about their bodies and work to promote their balance, flexibility and stability. This ultimately restores their ability to work and play, as well as be proactive in their own healing and mobility. Our goal is to help our local island community stay as active and independent as they can, to empower them to have the tools to decrease and control pain, and to optimize functional mobility as they age.","location":"Kealakekua","rating":5,"lat":19.517688,"lng":-155.922165,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"5d527ca6-99a5-4b3a-81e1-31eca8506ef9","name":"Roxanne Cedor","title":"$undefined","businessName":"Kona Mobile PT","image":"https://konamobilept.com/wp-content/uploads/2025/07/a2.webp","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Recover, move better, and feel stronger—without leaving home. Kona Mobile PT delivers expert physical therapy and wellness care directly to your home or vacation rental in Kailua-Kona and surrounding areas. No clinic, no waiting rooms—just personalized one-on-one care, on your schedule.","location":"Kailua-Kona","rating":5,"lat":19.690883,"lng":-156.021213,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"dda686f3-aa8d-4fa2-a956-b2ffe95cbf9e","name":"Physical Therapy.","title":"$undefined","businessName":"Pure Fit Physical Therapy and Pelvic Health","image":"https://framerusercontent.com/images/lLsgl4NVWS1UALlBmbjLivUJPPo.png","type":"practitioner","modality":"Physical Therapy, Women's Health","modalities":["Physical Therapy","Women's Health"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Pure Fit physical therpay and pelvic health begins with a simple intention: to help you move with more ease, strength, and trust in your body. Whether youâre healing, rebuilding, or growing, we meet you where you are and guide you forward with care.","location":"Hilo","rating":5,"lat":19.721024,"lng":-155.084329,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"155f2786-b513-42ea-a2bd-7a945d47d2e0","name":"Stephanie Colasanti","title":"$undefined","businessName":"Therapydia Kona","image":"http://therapydiacalifornia.com/wp-content/uploads/2024/09/physical-therapy-reviews-happy-customer-satisfied-1-1.png","type":"practitioner","modality":"Physical Therapy","modalities":["Physical Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Therapydia Kona physical therapy clinic uses state-of-the-art equipment and