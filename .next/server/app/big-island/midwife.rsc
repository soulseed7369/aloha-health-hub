me.","location":"Honokaa","rating":5,"lat":20.075967,"lng":-155.470173,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"3cbabd6b-02ca-4e9d-8f03-7aaf686929bc","name":"Taylor Hamil","title":"$undefined","businessName":"Banyan Birth LLC","image":"http://static1.squarespace.com/static/5cba55b3a09a7e30cda8e8be/t/612a8c8da3377b31438ab731/1630178459705/filip-kowalski-FsSpOI_Fx_8-unsplash.jpg?format=1500w","type":"practitioner","modality":"Midwife, Women's Health","modalities":["Midwife","Women's Health"],"sessionType":"in_person","acceptsNewClients":true,"bio":"taylor hamil MS, LM, LMT, CPM.  trauma informed midwifery care.  home birth. maya abdominal therapy. craniosacral therapy. neurofeedback. SERVING THE BIG ISLAND OF HAWAI’I","location":"Holualoa","rating":5,"lat":19.619649,"lng":-155.948743,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"8fa15555-d974-413f-ac4e-eb26538f68cf","name":"Laulima Midwifery","title":"$undefined","businessName":"Laulima Midwifery","image":"https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=400,h=464,fit=crop/YBg4ja4joZuXgLpO/mimundoamarillo-73-Y4LJP7BGK3Fx2O4o.jpg","type":"practitioner","modality":"Midwife, Women's Health","modalities":["Midwife","Women's Health"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Experience personalized care with licensed midwife offering massage, herbs, and prenatal services in dark red ambiance. Your health and comfort are our top priorities.","location":"Captain Cook","rating":5,"lat":19.493257,"lng":-155.917086,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[],"totalPractitioners":6,"totalCenters":0,"citiesServed":["Captain Cook","Hilo","Holualoa","Honokaa","Kealakekua","Waimea"]}]]
