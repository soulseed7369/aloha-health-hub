bpage! http://hoonaneamassage.com.","location":"Hilo","rating":5,"lat":19.693195,"lng":-155.068916,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"b1cb52b2-7c71-4f71-9f9c-b84879819b0d","name":"Island Breeze Massage","image":"https://islandbreezemassage.com/wp-content/uploads/2024/11/s1.jpg","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Relax and rejuvenate with the best Kona massage at Island Breeze Massage. Experience Deep Tissue, Lomi Lomi, Swedish, and Couples Massage. Book your session today and discover true relaxation.","location":"Kailua-Kona","rating":5,"lat":19.67317,"lng":-156.01564,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"7a54da69-04a2-4dee-9585-ea6417d04fa3","name":"Jamie Belmarez","businessName":"Jamie Eversweet Belmarez","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/practitioners/1773111631184-yk06pl6zcnq.png","type":"practitioner","modality":"Massage, Yoga","modalities":["Massage","Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Jamie Eversweet Belmarez is a licensed massage therapist and certified yoga teacher working in the field since 2001.\n\nHer passion for massage and bodywork began as a young child, learning from her mother about the power of healing touch.\n\nJamie’s massage style is a balance of eastern and western with education in and experience including Thai Yoga massage, Shiatsu, Reiki, Tui Na and cupping as well as western modalities such as trigger point therapy, connective tissue release techniques, compassionate inquiry, deep tissue therapy, kinesiology, neuromuscular facilitation and more.\n\nJamie likes to attend to the source of imbalances rather than \"chase the pain\" or \"fix\" people. She has a dynamic practice and is committed to working with you to release and balance.","location":"Kapaau","rating":5,"lat":20.230819,"lng":-155.799408,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"c01e5f8b-fd16-4e56-92dc-cdd6e39f9ae3","name":"Waiono Bodyworks","businessName":"Waiono Bodyworks","image":"https://bdaa9788bddab3c10ad9-22be5b9fdbd2e3f0d0326788b613007a.ssl.cf2.rackcdn.com/340x340/wprto_temp_168571923_197613_$2025_02_17_15_01_41_1216.png","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"When booking an appt online as a BodyPro client, please note in comments.","location":"Waimea","rating":5,"lat":20.037342,"lng":-155.826787,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"117250e7-6a64-4652-9707-c24f4b0414ec","name":"Jarica Barr","businessName":"Tree of Life Healing","image":"https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=254,fit=crop,q=95/mv079p6rxjHl1plG/img_1531-AoPGzMkWyafa9jKk.jpg","type":"practitioner","modality":"Acupuncture, Ayurveda, Massage","modalities":["Acupuncture","Ayurveda","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Explore the transformative benefits of acupuncture, therapeutic massage, and Ayurveda in our holistic approach to health. Experience natural healing and wellness that nurtures both body and mind for a balanced life.","location":"Pāhoa","rating":5,"lat":19.470675,"lng":-154.92233,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"80f50c8b-b953-4fde-861b-975668c0167d","name":"Myosomatic Therapy","businessName":"Myosomatic Therapy","image":"","type":"practitioner","modality":"Somatic Therapy, Massage","modalities":["Somatic Therapy","Massage"],"sessionType":"in_pers