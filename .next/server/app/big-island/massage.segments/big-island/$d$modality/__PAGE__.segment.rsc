3:["$","$L6",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"massage","modalityName":"Massage","practitioners":[{"id":"73ae3acb-fc2a-40b3-8d0b-93c1c6c25271","name":"808 Bodyworx","image":"https://img1.wsimg.com/isteam/ip/36fe7e49-c245-4e51-b39a-17e47cb66407/logo-horizontal-transparent.png","type":"practitioner","modality":"Massage, Alternative Therapy","modalities":["Massage","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"I'll help you achieve your performance goals with my customizable pain relief services.","location":"Hilo","rating":5,"lat":19.722841,"lng":-155.089682,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"7099ae2a-9c26-466a-b507-469007a3b624","name":"A Touch of Heaven Massage","image":"https://le-cdn.hibuwebsites.com/ecffbc5dc63e4c838b1ec99438edfdfa/dms3rep/multi/opt/RSshutterstock_133587734-1056w.jpg","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"808-937-2711 - Find out about our range of massage services, acupuncture services, and more at A Touch of Heaven Massage Therapy.","location":"Hilo","rating":5,"lat":19.725496,"lng":-155.087805,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"05d218eb-a2d9-486a-9c83-476704010dfd","name":"A Touch of Tranquility, LLC","image":"","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"location":"Waimea","rating":5,"lat":20.025421,"lng":-155.659659,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"045520a1-105f-40bb-92cc-09e6a1f00cc6","name":"Massage Big Island","businessName":"Massage Big Island","image":"https://massagebigisland.com/assets/images/card.jpg?v=7f9cccd7","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Experience expert Lomi, Swedish, and deep tissue massage in Hawi and the Kohala Coast. Beach massage and in-home sessions available. Book now!","location":"Hawi","rating":5,"lat":20.237111,"lng":-155.832114,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"5b28362d-4c28-49f7-91f7-9903ee84d005","name":"Ainalako Healing Massage","image":"http://img1.wsimg.com/isteam/getty/925179788","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Experience the ultimate healing touch and relaxation massage that my customers rave about in their reviews.","location":"Hilo","rating":5,"lat":19.643782,"lng":-155.088582,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"cd8de390-2305-4ede-a6b9-2d5c48742e3e","name":"Alicia Valley","businessName":"The Quiet Touch","image":"","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"","location":"Hilo","rating":5,"lat":19.730705,"lng":-155.089768,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"004d65bc-9437-4e2d-a5d4-ae2da6ffcf67","name":"Aloha Nani Massage","image":"https://www.alohananimassage.com/images/sites/27842/665301.png","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Nani Dickens provides world-class massage therapy in Kamuela HI. Call and start improving your health today: (808) 896-9343","location":"Waimea","rating":5,"lat":20.0248,"lng":-155.66017,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"0edcd51c-69cd-4a77-8c1b-342b4040882e","name":"Aloha Therapeutics","businessName":"Hinia Records LLC","image":"https://static.wixstatic.com/media/88aac0_aa8d3a4cb3e44afdbe2eabd7621c4193~mv2.jpeg/v1/fill/w_82,h_82,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/88aac0_aa8d3a4cb3e44afdbe2eabd7621c4193~mv2.jpeg","type":"practitioner","modality":"Craniosacral, Massage","modalities":["Craniosacral","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Aloha Therapeutics Wellness Clinic in downtown Hilo. Relax and Revitalize.  Accepting new patients. Workers compensation, no fault auto accidents, VA insurance. High quality experienced LMT's trained in mixed modalities including but not limited to Shiatsu Acupressure, Cranial Sacral Therapy, Tuina (Chinese manual therapy), Neuromuscular Reset, Structural Integration, Swedish/Relaxation massages.","location":"Hilo","rating":5,"lat":19.722458,"lng":-155.086856,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"e5c0954d-7fca-4fff-9995-2af473a611a1","name":"Relax. Restore. Reset.","businessName":"Le Manaia Massage LLC","image":"https://www.lemanaiamassage.com/wp-content/uploads/2026/02/02282026_Flyer_LeManaiaMassage.jpg","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"I started my journey into massage therapy back in 2016, inspired by my dad, who taught me what it means to give back and help others. I wanted to embrace this passion and after completing my education and training from Hokulani Massage Academy, I became a licensed massage therapist in 2017.","location":"Waimea","rating":5,"lat":20.025413,"lng":-155.659573,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"4b3100e5-b2c5-4fc6-97e4-6eb19865f51c","name":"Natural Balance","businessName":"Natural Balance","image":"https://naturalbalancehawaii.com/wp-content/uploads/2026/02/20251202_142428.jpg","type":"practitioner","modality":"Acupuncture, Massage","modalities":["Acupuncture","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Educated, experienced and effective practitioners in a family run alternative medicine clinic.","location":"Pahala","rating":5,"lat":19.276218,"lng":-155.474947,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"8a8ef3f4-12cd-454a-ab3a-f9e731aaf11c","name":"HAWAII ISLAND ACUPUNCTURE IN NA'ALEHU","businessName":"HAWAII ISLAND ACUPUNCTURE","image":"https://www.hawaiiislandacupuncture.com/uploads/2/3/9/4/23947285/published/img-5702.jpg?1694223227","type":"practitioner","modality":"Acupuncture, Massage","modalities":["Acupuncture","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Acupuncture Hawaii, Naalehu, chinese acupuncture, herbal medicine, chinese herbal medicine, cupping, acupuncture treatment, Chinese medicine, acupuncturist, acupuncturist,  herbs, healing, massage, shiatsu","location":"Naalehu","rating":5,"lat":19.0433,"lng":-155.614479,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"c8cdcae6-33a6-468f-90da-81dab942dc2d","name":"How To Find Me:","businessName":"Aloha Healing Spirit","image":"https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=130,fit=crop,q=95/AR0eWyX2RvT4NBDE/screenshot_20241220_191319_photos-m7V5jGKKqWCl7Kzv.jpg","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Do you experience chronic pain, tension, or stress and would like to get massages regularly to help with specific conditions, traumas, and injuries? Are you pregnant or postpartum and need some extra nurturing? I offer packages and membership options to make regular massage therapy affordable so you can invest in your health and well-being.","location":"Pahoa","rating":5,"lat":19.532756,"lng":-154.915901,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"a0c3f717-4b3e-4a20-893d-0c8314e56738","name":"Angee Lincoln-Smith","image":"https://lirp.cdn-website.com/190d8de0/dms3rep/multi/opt/massage-on-beach-1920w.jpg","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Born and raised in the serene surroundings of Kailua-Kona, Hawaii, Angee’s journey as a Massage Therapist began in childhood. Guided by her grandmother's wisdom, she discovered her passion for massage therapy while learning the art of reflexology at her grandmother’s side. This early experience ignited a lifelong commitment to serving and healing others.\n\nIn 2001, Angee officially became a Massage Therapist, later expanding her expertise as an Esthetician in 2006. Over the years, she’s had the privilege of working in prestigious resorts, luxurious spas, and clinical settings, including a Chiropractor's office, both in Kailua-Kona, Hawaii and Honolulu, Oahu. Throughout her career, Angee has witnessed the transformative power of massage therapy in restoring health and fostering the body's innate healing abilities.","location":"Kailua-Kona","rating":5,"lat":19.720986,"lng":-156.00859,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"7de0421c-fb09-498d-b104-4b7901edb6aa","name":"Ann Rothstein","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/a2409cf03299995fd44be67049be6d0f.jpg","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Ann has called the Big Island home since 1970. Deeply connected to the land and spirit of Hawai‘i, she brings over two decades of experience and a grounded presence to her healing work. Professionally trained in medical massage at the Hawaiian Islands School of Body Therapy, Ann has developed a practice rooted in skill, intuition, and deep listening to the body. She specializes in an integrative approach, blending modalities such as Myofascial Release, Lomi Lomi, Swedish, Trigger Point Therapy, ","location":"Holualoa","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"4bf759ea-289d-467b-9ad2-506bc2e016cc","name":"Awakening Hilo Massage","image":"http://awakeninghilo.massagetherapy.com/images/13962964_1244061258959759_3746311114655198661_o.jpg","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Since 2015, we've been honored to offer a sanctuary for rest, renewal, and reconnection. With a compassionate and intuitive approach, we provide deeply therapeutic massage modalities - including Deep Tissue, Lomi Lomi, Thai, and Relaxation massage- each tailored to meet the unique needs of every body and spirit.","location":"Hilo","rating":5,"lat":19.726001,"lng":-155.088236,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"d6ea50bb-da00-42f8-b084-5d76c1732d3f","name":"Balanced Beauty","image":"http://static1.squarespace.com/static/66f378ef11a6d16e2d9690e4/t/6750c9732c412526858f6400/1733347699854/DominiAdjustedLogoBlack.png?format=1500w","type":"practitioner","modality":"Massage","modalities":["Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Our facial massage activates your vagus nerve, bringing your whole body into a state of relaxation.","location":"Hilo","rating":5,"lat":19.726269,"lng":-155.087678,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"6d597b73-7d98-45da-9e60-a077681c5056","name":"Banyan Massag