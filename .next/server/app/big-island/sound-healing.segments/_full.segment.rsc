"bio":"$undefined","workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"5d22b28d-39ac-4e52-b613-de1552895cbf","name":"Yoga Hale","image":"https://static.wixstatic.com/media/1e0093_e63300b0dc534b32b1a7754dd23e4990~mv2.jpg/v1/fill/w_2200,h_634,al_c/1e0093_e63300b0dc534b32b1a7754dd23e4990~mv2.jpg","modality":"Somatic Therapy, Sound Healing, Yoga","modalities":["Somatic Therapy","Sound Healing","Yoga"],"location":"Kailua-Kona","rating":5,"lat":19.59052,"lng":-155.969676,"services":[],"tier":"free","description":"For over 20 years, Yoga Hale has been Kona’s trusted yoga studio on the Big Island of Hawaii, offering traditional and hot yoga just steps from Magic Sands Beach. We’re now expanding into wellness with new services including cryotherapy, lymphatic drainage, red light therapy, PEMF, and compression recovery — all focused on reducing pain, inflammation, and supporting true healing. Wellness isn’t a trend — it’s a lifestyle.","centerType":"yoga_studio","centerTypeLabel":"Yoga Studio","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://static.wixstatic.com/media/1e0093_e63300b0dc534b32b1a7754dd23e4990~mv2.jpg/v1/fill/w_2200,h_634,al_c/1e0093_e63300b0dc534b32b1a7754dd23e4990~mv2.jpg"],"bio":"$undefined","workingHours":{},"acceptsNewClients":true,"verified":true}],"totalPractitioners":6,"totalCenters":7,"citiesServed":["Captain Cook","Hilo","Holualoa","Kailua-Kona","Keaau","Kealakekua","Na Alehu","Pāhoa","Waimea"]}]
