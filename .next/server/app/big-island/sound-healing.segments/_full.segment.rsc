14:["$","$L15",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"sound-healing","modalityName":"Sound Healing","practitioners":[{"id":"82e89581-abd3-460a-9651-7894b06ca9cf","name":"Amma Sophia Rose","title":"$undefined","businessName":"Sonic Love Alchemy","image":"http://soniclovealchemy.com/cdn/shop/files/210810AmmaSophia0035_1200x1200.jpg?v=1723593160","type":"practitioner","modality":"Sound Healing","modalities":["Sound Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Sonic Love Alchemy's handcrafted crystal sound healing instruments are designed to elevate consciousness through sound. Discover yours today!","location":"Hilo","rating":5,"lat":19.663306,"lng":-155.113418,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"dfdfb47f-24b6-413a-8313-c0751955bf6c","name":"Benedick Howard","title":"$undefined","businessName":"$undefined","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1774778746414-jci3qkitdnm.webp","type":"practitioner","modality":"Longevity, Sound Healing","modalities":["Longevity","Sound Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Rebellious longevity coaching rooted in 40 years of electro-bio-physics, volcanic fasting, and bioelectric healing. Reclaim your cellular voltage, deprogram the sick-care system, and architect a life of unshakable biological sovereignty. Big Island.","location":"Keaau","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:57:40.654703+00:00","verified":false},{"id":"f75b67df-0803-4b53-8259-56255e3c7b20","name":"Dana Forrest","title":"$undefined","businessName":"Island Oasis Holistic","image":"https://static.wixstatic.com/media/cc4a6b_422e4c9f634e4e3baf99498185593534%7Emv2.png/v1/fit/w_2500,h_1330,al_c/cc4a6b_422e4c9f634e4e3baf99498185593534%7Emv2.png","type":"practitioner","modality":"Alternative Therapy, Meditation, Sound Healing","modalities":["Alternative Therapy","Meditation","Sound Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":" Island Oasis Holistic provides a safe, sacred space that enables our clients to explore their wellness journey through Sound Healing, Meditation, and Self-inquiry. Each person is the expert of their own life and has the innate capacity for strength, resilience, creativity, and well-being. ","location":"Hilo","rating":5,"lat":19.725238,"lng":-155.086221,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"586d698d-bcee-4f7a-85cf-6cf52def6fa8","name":"Kelley Rasch","title":"$undefined","businessName":"Sacred Healing Journeys","image":"https://static.wixstatic.com/media/e6324a_dca09d1780974e17a5df2772f7490d20~mv2_d_3442_2328_s_2.jpg/v1/fill/w_147,h_99,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/e6324a_dca09d1780974e17a5df2772f7490d20~mv2_d_3442_2328_s_2.jpg","type":"practitioner","modality":"Massage, Sound Healing, Reiki, Energy Healing","modalities":["Massage","Sound Healing","Reiki","Energy Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Healing Massage, Bodywork, Roxiva light therapy, and Sound Journeys  in Puna, Hawaii since 2012. Come experience a vibrational massage using the frequency of tuning forks at Sacred Healing Journeys. Massage Pahoa","location":"Keaau","rating":5,"lat":19.589906,"lng":-154.940341,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:57:41.073487+00:00","verified":false},{"id":"17c212fd-c9ca-45bd-a6d6-fb93502575bb","name":"Kelley Sypher","title":"$undefined","businessName":"$undefined","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/practitioners/1774855104709-uieux2qo5y.webp","type":"practitioner","modality":"Sound Healing, Energy Healing","modalities":["Sound Healing","Energy Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"I’m Kelley, Reiki Shinpiden, Sound Healer, Intuitive, Artist, Herbalist, and Spiritual Coach. Allow me to guide you to relax and realign. Body, mind and spirit. Restore for your highest good. I am honored to offer heart-centered sessions by donation.","location":"Na Alehu","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:57:41.712382+00:00","verified":false},{"id":"dedf8614-a0f8-475d-ae31-52f3ca1a89c6","name":"Lava Spiritual Oasis","title":"$undefined","businessName":"$undefined","image":"https://scontent.fhnl3-1.fna.fbcdn.net/v/t39.30808-1/452525969_1090233429486021_1134361770636136739_n.jpg?stp=dst-jpg_tt6&cstp=mx1012x1012&ctp=s720x720&_nc_cat=108&ccb=1-7&_nc_sid=3ab345&_nc_ohc=M1xe7_5wDHEQ7kNvwG1JHVP&_nc_oc=AdoJA_Fyc9Xzp_54xrIwISiorhzpcFzKSdC_mpwQ5ih7xEIoXVqtuFd1d0SOZI76SmI&_nc_zt=24&_nc_ht=scontent.fhnl3-1.fna&_nc_gid=ekEDNVUHsPSpfJ68z2LoXA&_nc_ss=7a30f&oh=00_AfwhfSqqqtVy1OXlbm9Qt5nqxQZgzexc8mSzkKTmug1yZQ&oe=69CEA91F","type":"practitioner","modality":"Reiki, Sound Healing","modalities":["Reiki","Sound Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Lava Spiritual Oasis. 203 likes. Massage Reiki Sound Healing Emotional Releasing. Short tours","location":"Pāhoa","rating":5,"lat":19.338414,"lng":-155.010831,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[{"id":"19a7c12a-c379-47db-99e5-11ebd1a66d62","name":"Around The Kava Bowl","image":"http://static1.squarespace.com/static/612a8396b4a24b2345b77bf3/t/612af67a93aaf06002e08dab/1630205562383/IMG_7926-1.jpg?format=1500w","modality":"Sound Healing, Alternative Therapy","modalities":["Sound Healing","Alternative Therapy"],"location":"Captain Cook","rating":5,"lat":19.493041,"lng":-155.916308,"services":[],"tier":"free","description":"Kava is a traditional Polynesian root beverage made from the root of the kava plant (Piper methysticum). It is related to the pepper plant, yes, like black pepper. Traditionally it was used ceremonially in weddings, political meetings and spiritual practices. In some parts of the Pacific, it was also consumed recreationally at social gatherings.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"bio":"$undefined","workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"9c5428ab-1cc9-4df2-8e63-728640ab4398","name":"Inner Alignment Studios","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772143150606_4dvzxqjztwd.jpeg","modality":"Alternative Therapy, Breathwork, Counseling, Lomilomi / Hawaiian Healing, Massage, Meditation, Naturopathic, Nervous System Regulation, Network Chiropractic, Osteopathic, Somatic Therapy, Sound Healing, Trauma-Informed Care, Yoga","modalities":["Alternative Therapy","Breathwork","Counseling","Lomilomi / Hawaiian Healing","Massage","Meditation","Naturopathic","Nervous System Regulation","Network Chiropractic","Osteopathic","Somatic Therapy","Sound Healing","Trauma-Informed Care","Yoga"],"location":"Kailua-Kona","rating":5,"lat":19.644823,"lng":-155.99752,"services":[],"tier":"free","description":"Inner Alignment Studios is a heart-centered wellness community space in Kailua-Kona, offering yoga classes, transformational events, and holistic experiences designed to support your whole self. From community circles and sound baths to seasonal ceremonies and workshops, we create spaces for connection, healing, and growth on Hawaiʻi’s Big Island.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772143150606_4dvzxqjztwd.jpeg"],"bio":"$undefined","workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"e3c50fbd-bce9-44e3-ae72-927eea318d4d","name":"Kona Cloud Forest Sanctuary","image":"https://konacloudforest.com/wp-content/uploads/sites/7497/2025/05/KCFS_batch1-70-of-139-1-1.jpg?w=700&h=700&zoom=2","modality":"Yoga, Sound Healing, Nature Therapy","modalities":["Yoga","Sound Healing","Nature Therapy"],"location":"Kailua-Kona","rating":5,"lat":19.705777,"lng":-155.947417,"services":[],"tier":"free","description":"Journey into the Mystical Kona Cloud Forest Sanctuary - Encounter Rare Species, Lush Greenery, and Peaceful Retreats. Find Your Paradise Today!","centerType":"retreat_center","centerTypeLabel":"Retreat Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"bio":"$undefined","workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"f8d6163f-75df-43eb-8968-de9718c382d8","name":"LONGEVITY LABS HAWAII","image":"http://static1.squarespace.com/static/6642ca8a9722f64abc99b407/t/685b54fb2eea6715dcb9e06f/1750815995235/LLH+social+image.png?format=1500w","modality":"Naturopathic, Longevity, Alternative Therapy, Nutrition, Sound Healing","modalities":["Naturopathic","Longevity","Alternative Therapy","Nutrition","Sound Healing"],"location":"Waimea","rating":5,"lat":19.941577,"lng":-155.858496,"services":[],"tier":"free","description":"Holistic Health Practice specializing in Metabolic Medicine Therapies and Cellular Regenerative Therapies. Custom Protocols, Nutrition and Lifestyle Programming for optimal health and wellbeing. Offering Sonic Vibration, Oxygen and Molecular Hydrogen Therapy, PEMF, Redlight Therapy, Sound Frequency","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"bio":"$undefined","workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"00d50832-b8bd-4943-9442-1f7e57767718","name":"Malama I Ke Ola","image":"http://