etwork Chiropractic, Physical Therapy","modalities":["Alternative Therapy","Counseling","Naturopathic","Network Chiropractic","Physical Therapy"],"location":"Kailua-Kona","rating":5,"lat":19.669411,"lng":-155.980051,"services":[],"tier":"free","description":"Discover Shockwave Therapy at Hawaii Wellness Clinic. Non-invasive treatment that relieves pain, promotes healing, and restores mobility through focused sound waves.","centerType":"clinic","centerTypeLabel":"Clinic","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"9c5428ab-1cc9-4df2-8e63-728640ab4398","name":"Inner Alignment Studios","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772143150606_4dvzxqjztwd.jpeg","modality":"Alternative Therapy, Breathwork, Counseling, Lomilomi / Hawaiian Healing, Massage, Meditation, Naturopathic, Nervous System Regulation, Network Chiropractic, Osteopathic, Somatic Therapy, Sound Healing, Trauma-Informed Care, Yoga","modalities":["Alternative Therapy","Breathwork","Counseling","Lomilomi / Hawaiian Healing","Massage","Meditation","Naturopathic","Nervous System Regulation","Network Chiropractic","Osteopathic","Somatic Therapy","Sound Healing","Trauma-Informed Care","Yoga"],"location":"Kailua-Kona","rating":5,"lat":19.644823,"lng":-155.99752,"services":[],"tier":"free","description":"Inner Alignment Studios is a heart-centered wellness community space in Kailua-Kona, offering yoga classes, transformational events, and holistic experiences designed to support your whole self. From community circles and sound baths to seasonal ceremonies and workshops, we create spaces for connection, healing, and growth on Hawaiʻi’s Big Island.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772143150606_4dvzxqjztwd.jpeg"],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"9013c4e1-0fa8-4c5e-80d4-62f41c0037a9","name":"Mana Wellness Massage Therapy & Holistic Health","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/729961b9d1321704102c925635d327f6.jpg","modality":"Alternative Therapy, Counseling, Herbalism, Lomilomi / Hawaiian Healing, Massage, Naturopathic, Network Chiropractic, Osteopathic","modalities":["Alternative Therapy","Counseling","Herbalism","Lomilomi / Hawaiian Healing","Massage","Naturopathic","Network Chiropractic","Osteopathic"],"location":"Hilo","rating":5,"lat":19.724544,"lng":-155.08623,"services":[],"tier":"free","description":"Nestled in downtown Hilo, Hawaii on the Big Island, Mana Wellness Massage Therapy & Holistic Health provides professional massage therapy at our convienient location at 224 Kamehameha Ave Ste 206 Hilo, HI 96720. Wehope you give yourself the opprotunity for some massage & relaxation at our small Spa.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"3f139bc5-5b7d-4a2c-8212-e0178371dd3a","name":"Ola Tropical Apothecary & Spa","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772142469143_aqkfpn09n1m.jpg","modality":"Acupuncture, Alternative Therapy, Counseling, Lomilomi / Hawaiian Healing, Massage, Naturopathic, Network Chiropractic","modalities":["Acupuncture","Alternative Therapy","Counseling","Lomilomi / Hawaiian Healing","Massage","Naturopathic","Network Chiropractic"],"location":"Hilo","rating":5,"lat":19.724624,"lng":-155.086117,"services":[],"tier":"free","description":"Enjoy our signature Full Body Massages, Lomilomi and Facial Treatments, as well as a la carte services such as Foot Soak, Foot Massages and Express 30 minute Massages. Let our experienced therapists rebalance your mind, body, heart and spirit. We are the only shop that carries ALL of the Ola products and we have samples of EVERYTHING which you can try and experience. Come visit Ola Tropical Apothecary & Spa, conveniently located in Downtown Hilo, Hawaii.","centerType":"spa","centerTypeLabel":"Spa","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772142469143_aqkfpn09n1m.jpg"],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"2b392063-48ce-422d-9013-5c7cc5baa9e0","name":"Trauma Healing Hawaii","image":"https://brightervisionclients.com/resize/66df3cadd83718f4d4371fae/attachments/43abadcf-dad0-40fa-81b5-7e7afa4cbae0","modality":"Alternative Therapy, Counseling, Massage, Meditation, Naturopathic, Network Chiropractic, Osteopathic, Somatic Therapy, Trauma-Informed Care, Yoga","modalities":["Alternative Therapy","Counseling","Massage","Meditation","Naturopathic","Network Chiropractic","Osteopathic","Somatic Therapy","Trauma-Informed Care","Yoga"],"location":"big_island","rating":5,"lat":0,"lng":0,"services":[],"tier":"free","description":"Trauma Healing Hawaii provides quality telehealth, individuals who experienced trauma, support group, psychodynamic, EMDR & yoga therapy services in Hawaii","centerType":"clinic","centerTypeLabel":"Clinic","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true}],"totalPractitioners":1,"totalCenters":6,"citiesServed":["Hilo","Kailua-Kona","Keaau","Kealakekua","big_island"]}]
