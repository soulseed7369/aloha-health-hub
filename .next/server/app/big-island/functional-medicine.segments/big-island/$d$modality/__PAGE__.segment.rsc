3:["$","$L6",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"functional-medicine","modalityName":"Functional Medicine","practitioners":[{"id":"ba9623c3-4612-4204-b035-68d1605a8f76","name":"Aaron Ishigo - Big Island Acupunture","businessName":"Big Island Acupunture","image":"https://www.bigislandacu.com/resources/Rustic%20Minimal%20Wedding%20Print%20Banner.png.opt798x399o0%2C0s798x399.png","type":"practitioner","modality":"Acupuncture, Herbalism, Functional Medicine","modalities":["Acupuncture","Herbalism","Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Located at 82 Keaʻa Street in beautiful Hilo, Hawaii, Big Island Acupuncture is honored to have been recognized as East Hawaii's Best Acupuncture for three consecutive years 2023, 2024 and 2025. Mahalo to our community for your continued trust and support!","location":"Hilo","rating":5,"lat":19.723955,"lng":-155.05891,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"fc5093bb-88c6-4bb8-90c0-ac0fd2a90d1e","name":"Ashley Mai Demaline","image":"https://static.wixstatic.com/media/11062b_95d34f15761e4114a57b17823228948ef000.jpg/v1/fill/w_288,h_162,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/11062b_95d34f15761e4114a57b17823228948ef000.jpg","type":"practitioner","modality":"Functional Medicine, Yoga","modalities":["Functional Medicine","Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Offering functional medicine, ayurvedic and medical marijuana consultations.","location":"Holualoa","rating":5,"lat":19.619758,"lng":-155.949169,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-04T05:20:02.625318+00:00","verified":false},{"id":"00cd6ebc-7ad8-499e-a99e-146e1abfdc62","name":"Carolyn Candido","image":"https://drcarolyncandido.com/wp-content/uploads/2023/01/IMG_2827-scaled.jpg","type":"practitioner","modality":"Functional Medicine","modalities":["Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Dr. Candido is committed to education of the medical community through organizing Functional Medicine Forums and as board member of Learn","location":"Kailua-Kona","rating":5,"lat":19.647713,"lng":-155.989093,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"d74edb34-27cf-4f63-8908-6388e2d0e144","name":"Christopher Lawinski","image":"https://www.hawaiiwholepersonhealing.com/wp-content/uploads/2020/06/fbgraph-1.jpg","type":"practitioner","modality":"Functional Medicine, Alternative Therapy","modalities":["Functional Medicine","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Field Control Therapy | Hawaii Whole Person Healing","location":"Pahoa","rating":5,"lat":19.492184,"lng":-154.941463,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"c4b58557-c9ab-4997-9f5e-40153c22d1de","name":"Happy. Healthy. Whole.","image":"http://www.iamhhw.com/wp-content/uploads/2018/03/foodmontage2-1.jpg","type":"practitioner","modality":"Functional Medicine","modalities":["Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"At Happy Healthy Whole we teach Nature’s Healing Laws, which are simple, easy to learn and offer life changing results. We support people through detoxification therapies to lighten the burden that’s been placed on their body, mind and soul. Many of us have accumulated years of toxic waste from our environment and food, as well as trauma and negative habit patterns that we have grown accustomed to living with. When we are ready, Spirit comes knocking and moves us to make a change in our lives. Detoxification is a necessary and natural step along our healing path to release what…","location":"Pāhoa","rating":5,"lat":19.398195,"lng":-154.9273,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"f3fc5084-9ad4-4953-b6a2-c0a63ee469e8","name":"Karen D. Johnson MD","image":"https://karendjohnsonmd.com/wp-content/uploads/2016/07/logo-2016.png","type":"practitioner","modality":"Functional Medicine","modalities":["Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Compassionate Care in a Healing Environment TELEMEDICINE CONSULTATIONS AVAILABLE","location":"Kapaau","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"49b78ff1-ebf1-44d2-a22e-c53ec2345867","name":"Michael Hughes - Kona Regenerative Medicine","businessName":"Kona Regenerative Medicine","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/avatars/1772329208338_pbexxc2wqwh.webp","type":"practitioner","modality":"Psychotherapy, Functional Medicine","modalities":["Psychotherapy","Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Kona Regenerative Medicine offers cutting-edge regenerative therapies in \nKailua-Kona, Hawaii. We specialize in non-surgical treatments for pain, \njoint injuries, and chronic conditions using PRP, EMTT, and Shockwave \nTherapy. Heal naturally. Move freely. Thrive fully.","location":"Kailua-Kona","rating":5,"lat":19.640379,"lng":-155.990472,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"58bbc01e-8a8b-42a7-b879-436bcb7577de","name":"Unity Nguyen MD LAc","businessName":"Dr. Unity Regenerative Health","image":"http://static1.squarespace.com/static/63ab82a9d5e53d3276cf10db/t/63c4a7a426955104853063e8/1673832356973/Logo+and+tagline+horizontal.png?format=1500w","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine), Functional Medicine","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)","Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"“Fatigue, fibromyalgia, anxiety, and a lot of stomach problems. I used to think I would be sick half the time for the rest of my life.  It’s like a miracle, the way her system works.  Even my skin got so nice, the wrinkles and bumps on my face are smaller.”","location":"Keaau","rating":5,"lat":19.600849,"lng":-154.946123,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[{"id":"70f5dab8-f665-4a3c-96df-2d964b490d39","name":"Advanced Wellness and Recovery","image":"https://www.advancedhawaii.com/","modality":"Functional Medicine, Alternative Therapy, Longevity","modalities":["Functional Medicine","Alternative Therapy","Longevity"],"location":"Kailua-Kona","rating":5,"lat":19.64494,"lng":-155.992732,"services":[],"tier":"free","description":"At Advanced Wellness and Recovery in Kailua-Kona, we use Integrative Medicine in Hawaii. Reverse the signs of aging and restore mental health. Contact us today!","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"72a85151-00ff-4bc3-b4d3-8d093da8bf1a","name":"Hamakua-Kohala Health","image":"https://www.hamakua-health.org/wp-content/uploads/elementor/thumbs/Honokaa-Clinic-pwukaue2aa2smd5k65oywnn6hvd3wphqqoai70b30g.png","modality":"Functional Medicine","modalities":["Functional Medicine"],"location":"Kapaau","rating":5,"lat":20.231703,"lng":-155.79689,"services":[],"tier":"free","description":"Hamakua-Kohala Health provides quality healthcare and wellness programs to the North Hawaii Communities. New patients welcome.","centerType":"clinic","centerTypeLabel":"Clinic","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"87bb430e-c2b6-473d-bf3b-7e0927dd4df3","name":"Hawaii Holistic Care","image":"https://lirp.cdn-website.com/2464e81b/dms3rep/multi/opt/social-image-1920w.png","modality":"Functional Medicine, Longevity, IV Therapy, TCM (Traditional Chinese Medicine), Acupuncture, Trauma-Informed Care, Somatic Therapy","modalities":["Functional Medicine","Longevity","IV Therapy","TCM (Traditional Chinese Medicine)","Acupuncture","Trauma-Informed Care","Somatic Therapy"],"location":"Kailua-Kona","rating":5,"lat":19.626512,"lng":-155.986455,"services":[],"tier":"free","description":"Whole-person healing with acupuncture, functional medicine & soul care. Community clinic & wellness center in Kailua-Kona. Insurance accepted.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"0e0da020-ea1c-49fc-a168-c5554e051959","name":"Oasis For Life Wellness Center Hawaii","image":"https://www.oflwc.com/wp-content/uploads/2021/05/cropped-oflwc512x512-01.png","modality":"Functional Medicine, Counseling","modalities":["Functional Medicine","Counseling"],"location":"Hilo","rating":5,"lat":19.717451,"lng":-155.076542,"services":[],"tier":"free","description":"Office Location: 101 Aupuni St. Suite 108 Hilo Hawaii 96720Contact # 8087564967 Email: oasishi@charter.net Tricia is a Licensed Clinical Pastoral Counselor with the National Christian Counselors Association. She moved to Hawaii (Big Island) in 2015 with a desire to faithfully serve the Lord and be a blessing to women, families, youth, and children. Tricia carries","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"17c2366f-f61b-4af9-872c-d1b27cc89639","name":"Pacific Quest","image":"https://pacificquest.org/wp-content/uploads/2026/01/PQ-website-logo-reverse-4e50f52f51a1d6b571b9f1ab11556430.png","modality":"Alternative Therapy, Counseling, Functional Medicine, Nutrition","modalities":["Alternative Therapy","Counseling","Functional Medicine","Nutrition"],"location":"Hilo","rating":5,"lat":19.725815,"lng":-155.060092,"services":[],"tier":"free","description":"Pacific Quest provides fully licensed and accredited residential mental healthcare on the Island of Hawaii. Our integrative, individualized approach combines specialized clinical care, nature-based experiences and holistic wellness to boost self-esteem, heal trauma, and get to the root cause of what might be holding residents back.","centerType":"clinic","centerTypeLabel":"Clinic","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"20fb11ba-9704-45d7-876f-a49af0ac5c90","name":"The Koa Clinic","image":"https://static.wixstatic.com/media/a3026b_fd7a53126e444dc7bd2799b210d800f4~mv2.jpg/v1/fill/w_1200,h_630,al_c/a3026b_fd7a53126e444dc7bd2799b210d800f4~mv2.jpg","modality":"Naturopathic, Functional Medicine, TCM (Traditional Chinese Medicine)","modalities":["Naturopathic","Functional Medicine","TCM (Traditional Chinese Medicine)"],"location":"Kailua-Kona","rating":5,"lat":19.626844,"lng":-155.981072,"services":[],"tier":"free","description":"Integrative primary health care & more in Kailua-Kona, Hawaii at The Koa Clinic. Our experienced team offers naturopathic, functional, and Traditional Chinese Medicine services, plus holistic wellness solutions for optimal health. Experience personalized, compassionate care in Kona today.","centerType":"clinic","centerTypeLabel":"Clinic","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true}],"totalPractitioners":8,"totalCenters":6,"citiesServed":["Hilo","Holualoa","Kailua-Kona","Kapaau","Keaau","Paho