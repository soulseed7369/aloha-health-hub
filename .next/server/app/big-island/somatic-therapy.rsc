modalities":["Counseling","Somatic Therapy","Psychotherapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Are you ready for change? I offer a Jungian approach to professional counseling including EMDR and Internal Family Systems (IFS).","location":"Kailua-Kona","rating":5,"lat":19.626512,"lng":-155.986455,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"9c07fa5a-25e8-4f83-b48e-901cc807cfc4","name":"GENELL HOWELL","title":"$undefined","businessName":"$undefined","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/avatars/1772145175707_2jnrce2tcgb.jpeg","type":"practitioner","modality":"somatic, Somatic Therapy","modalities":["somatic","Somatic Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Genell Howell mental health counselor, somatic experiencing practitioner. Genell uses a whole person approach to therapy to help integrate the body, mind, and soul and develop greater healing and resiliency. She uses Somatic Experiencing, EMDR, Brainspotting, Sandplay, expressive arts therapy, and a Depth oriented Jungian approach to her therapeutic style. ","location":"Kona","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"80f50c8b-b953-4fde-861b-975668c0167d","name":"Myosomatic Therapy","title":"$undefined","businessName":"Myosomatic Therapy","image":"","type":"practitioner","modality":"Somatic Therapy, Massage","modalities":["Somatic Therapy","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Soft-Tissue manipulation for chronic pain, injury and rehabilitation.","location":"Hilo","rating":5,"lat":19.724952,"lng":-155.087041,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"98d44f3a-e27f-4981-94da-6fa666a896d4","name":"Laura Moorhead","title":"$undefined","businessName":"$undefined","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/39b2a6c42d2e3c93ad504c45e12ed07f.jpg","type":"practitioner","modality":"Craniosacral, Somatic Therapy","modalities":["Craniosacral","Somatic Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"CranioSacral in Kamuela & Hawi","location":"Waimea","rating":5,"lat":20.023427,"lng":-155.676644,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"0e5051aa-71e4-4aca-a2de-7b829c301b73","name":"Margaret Eyles","title":"$undefined","businessName":"$undefined","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/c7b72ff7d50be646055092ee60bfb5a0.jpg","type":"practitioner","modality":"Massage, Somatic Therapy, Craniosacral","modalities":["Massage","Somatic Therapy","Craniosacral"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Margaret became a certified Rolfer® in 1988 and a Certified Rolf Movement® Teacher in 1995, and later achieved my Advance Rolfing certification. In addition to that training she is also a certified massage therapist and has trained in Cranial-Sacral Therapy. She believes in educating her clients so that they may develop their inherent ability to heal themselves, for they are the best authority regarding their physical well-being. Margaret lives in Holualoa near Kona on the Big Island of Hawaii and finds refuge in the sea as both a swimmer and free diver. She was exposed to the healing arts at…","location":"Holualoa","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"e6b9190b-3712-4822-a948-eb68658ff6f7","name":"Upcoming Offerings","title":"$undefined","businessName":"Wild Women Hawai'i LLC","image":"https://static.wixstatic.com/media/4bf6fb_269e