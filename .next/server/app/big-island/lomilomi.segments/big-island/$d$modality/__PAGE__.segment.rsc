3:["$","$L6",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"lomilomi","modalityName":"Lomilomi / Hawaiian Healing","practitioners":[{"id":"11b134de-1089-4cca-841c-203d8b208c56","name":"Christy Mulvey","image":"https://www.lomilomikona.com/image/40410945.jpg","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"By visiting this website you've taken your first step towards health and healing. Please feel free to look around the site to learn about what I have to offer. And when you're ready to begin your transformation, Call or Text me and we'll set up your first appointment.","location":"Kailua-Kona","rating":5,"lat":19.610086,"lng":-155.975429,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"713d633c-1ce2-4f70-a794-52ed3e5fa902","name":"The Goal.","image":"http://static1.squarespace.com/static/65d8161ed7be7b012d24f809/t/65f271f5dd3993160e181a1b/1710387705819/OHIA+LOGO.jpg?format=1500w","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Therapeutic Massage creates a relaxing environment for your body and nervous system. Helping circulate blood to injured areas and provide relief.","location":"Kailua-Kona","rating":5,"lat":19.644222,"lng":-155.996912,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"a43e71ba-6bec-4810-9421-06ff0f50aeb1","name":"Emily To - Body Compass Massage","businessName":"Body Compass Massage","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/avatars/1772149709276_j7escrty23a.webp","type":"practitioner","modality":"Massage, Life Coaching, Lomilomi / Hawaiian Healing","modalities":["Massage","Life Coaching","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Body Compass Massage is a professionally licensed therapeutic massage establishment in Kailua-Kona, Hawaii. Techniques include Deep Tissue, Hawaiian Lomi Lomi, Thai, Hot Stone, Cupping, Reflexology,  Myofascial Release, and Trigger Point Therapy.","location":"Kailua-Kona","rating":5,"lat":19.64,"lng":-155.9969,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"b1cb52b2-7c71-4f71-9f9c-b84879819b0d","name":"Island Breeze Massage","image":"https://islandbreezemassage.com/wp-content/uploads/2024/11/s1.jpg","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Relax and rejuvenate with the best Kona massage at Island Breeze Massage. Experience Deep Tissue, Lomi Lomi, Swedish, and Couples Massage. Book your session today and discover true relaxation.","location":"Kailua-Kona","rating":5,"lat":19.67317,"lng":-156.01564,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"22222ba0-7ae5-4048-a3d3-cde408ed98ef","name":"Lanilomi Massage Therapy","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/practitioners/1775326809601-ou0smjt1tt.webp","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Signature Lomilomi and therapeutic massage in Kailua-Kona. Private studio sessions and mobile massage along the Kona coast. Customized, intuitive, and rooted in traditional Hawaiian healing.","location":"Kailua-Kona","rating":5,"lat":19.626512,"lng":-155.986455,"tier":"free","island":"big_island","updatedAt":"2026-04-04T18:20:11.251472+00:00","verified":false},{"id":"6346f5c7-d3fe-431b-b9e2-83a2416a1ee2","name":"Thom & Mayumi","image":"https://www.ncihawaii.com/wp-content/uploads/2025/12/Screenshot_20251202_143912_M365-Copilot.jpg","type":"practitioner","modality":"Massage, Life Coaching, Lomilomi / Hawaiian Healing, Craniosacral","modalities":["Massage","Life Coaching","Lomilomi / Hawaiian Healing","Craniosacral"],"sessionType":"in_person","acceptsNewClients":true,"bio":"⭐Guiding Humanity on its Journey to Holistic Health  🇺🇸Honoring Our VeteransFree Massage from Nature Care Inc. To keep our holistic health treatments affordable and assist those in financial distress, we offer our services on a sliding scale. Your cost will range from 85 to 135 dollars per hour +tax depending on your situation. To schedule your appointment … Continue reading \"Nature Care Hawaii\"","location":"Hilo","rating":5,"lat":19.71616,"lng":-155.078722,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"b56766be-4e86-4f52-93da-22f481adcf84","name":"Therapeutic Massage","businessName":"Ola I Ke Aloha Massage LLC","image":"http://static1.squarespace.com/static/65a9ec5f4dcb293b40644979/t/678b68d375fd160101abb394/1737189587167/4draftPUNI%27S_LOGO_SensationQualities_Font1+%282%29.PNG?format=1500w","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"\"Ola I Ke Aloha Massage - Professional Massage therapy in Kailua Kona, Hawaii and Hilo, Hawaii. Offers lomilomi, therapeutic, prenatal, myofascial release, reflexology, ashiatsu, deep tissue manual lymphatic drainage, cupping, ion cleanse and more.  Offers a wide variety of massage modalities i","location":"Hilo","rating":5,"lat":19.726269,"lng":-155.087678,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"cc3fbaa7-3983-42a4-a08c-8cad0c165e16","name":"Reverend Kahu Jamie Kahealani Francisco","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/practitioners/1774912441698-ipmo6t0euc9.webp","type":"practitioner","modality":"Hawaiian Healing, Psychic, Reiki, Lomilomi / Hawaiian Healing","modalities":["Hawaiian Healing","Psychic","Reiki","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Keep mindful thoughts, words, and deeds.","location":"Captain Cook","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:57:39.764856+00:00","verified":false},{"id":"db98ab51-6882-47f5-9017-24b267cce319","name":"Sylvie Gendron, Massage and Lomilomi","image":"https://static.wixstatic.com/media/f59bc3_555121e4b44a4adda737bbf44dad26fa~mv2.jpg/v1/fill/w_2500,h_1472,al_c/f59bc3_555121e4b44a4adda737bbf44dad26fa~mv2.jpg","type":"practitioner","modality":"Massage, Energy Healing, Lomilomi / Hawaiian Healing, Hawaiian Healing, Watsu / Water Therapy","modalities":["Massage","Energy Healing","Lomilomi / Hawaiian Healing","Hawaiian Healing","Watsu / Water Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Sylvie Gendron; Licensed Massage Therapist, Hawaiian Lomilomi . Therapeutic sessions, in lower Puna Pahoa, relaxing, and healing for body, mind and spirit. \nOver 25 years experience.","location":"Pahoa","rating":5,"lat":19.401889,"lng":-154.921036,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:57:41.836456+00:00","verified":false},{"id":"e86f040f-cb41-4a60-aba2-2a1977d51c0d","name":"Teresa Navarro","businessName":"Ka Lima Hana Kukui \"Hawaiian Massage Therapy\"","image":"http://lomilomihawaii.net/images/home.jpg","type":"practitioner","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Hawaii Lomi Lomi massage is a manual therapeutic procedure that uses touch to treat the muscular structures of the body. There are several  different types of massage techniques including: Hawaiian Lomi Lomi, Swedish, Deep Tissue Point Thereapy, Shiatsu, Sports Massage, and Reflexology.  Massage is used to relieve stress, increase blood flow, soothe aches and pain, relax tense muscles, and increase the general well-being of the body.","location":"Kailua-Kona","rating":5,"lat":19.604837,"lng":-155.962419,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[{"id":"f2893c1a-5f3b-4528-ba73-64e165182282","name":"Aloha Massage Academy","image":"http://static1.squarespace.com/static/5e1a474cb5698248bf266f63/t/5e6e7ff1e095af7f34f896e4/1584300030725/Aloha+Massage+Academy+logo+transparent+teal+letters.png?format=1500w","modality":"Massage, Lomilomi / Hawaiian Healing","modalities":["Massage","Lomilomi / Hawaiian Healing"],"location":"Kealakekua","rating":5,"lat":19.531566,"lng":-155.925838,"services":[],"tier":"free","description":"Join instructor Angela Leslee, LMT in a 20 hour, CEU accredited Mana Lomi® workshop. This style of Lomilomi taught by her kumu Dr. Maka'ala Yates, is in the lineage of world famous Lomi master Aunty Margaret.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"8ba59609-22b4-49ae-8232-6285f71d542f","name":"Hale Ho‘ōla Hawaiian Healing Arts Center and Spa","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1772142734449_5yxxvet3qqc.jpg","modality":"Alternative Therapy, Lomilomi / Hawaiian Healing, Naturopathic","modalities":["Alternative Therapy","Lomilomi / Hawaiian Healing","Naturopathic"],"location":"Volcano","rating":5,"lat":19.42483,"lng":-1