odalities":["Massage","Lomilomi / Hawaiian Healing","Somatic Therapy"],"location":"Holualoa","rating":5,"lat":19.619957,"lng":-155.94921,"services":[],"tier":"free","description":"Foot Reflexology Massage, Paʻakai (sea salt scrub), Somatic Experiencing. Education to become a Licensed Massage Therapist and in Foot Reflexology Massage.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://static.wixstatic.com/media/bb88b6_c90abb15e63145a1ad1216fdaa3750d6%7Emv2.jpg/v1/fit/w_2500,h_1330,al_c/bb88b6_c90abb15e63145a1ad1216fdaa3750d6%7Emv2.jpg"],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"9013c4e1-0fa8-4c5e-80d4-62f41c0037a9","name":"Mana Wellness Massage Therapy & Holistic Health","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/729961b9d1321704102c925635d327f6.jpg","modality":"Alternative Therapy, Counseling, Herbalism, Lomilomi / Hawaiian Healing, Massage, Naturopathic, Network Chiropractic, Osteopathic","modalities":["Alternative Therapy","Counseling","Herbalism","Lomilomi / Hawaiian Healing","Massage","Naturopathic","Network Chiropractic","Osteopathic"],"location":"Hilo","rating":5,"lat":19.724544,"lng":-155.08623,"services":[],"tier":"free","description":"Nestled in downtown Hilo, Hawaii on the Big Island, Mana Wellness Massage Therapy & Holistic Health provides professional massage therapy at our convienient location at 224 Kamehameha Ave Ste 206 Hilo, HI 96720. Wehope you give yourself the opprotunity for some massage & relaxation at our small Spa.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"3f139bc5-5b7d-4a2c-8212-e0178371dd3a","name":"Ola Tropical Apothecary & Spa","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/o