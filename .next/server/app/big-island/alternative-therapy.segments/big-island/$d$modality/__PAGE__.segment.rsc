3:["$","$L6",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"alternative-therapy","modalityName":"Alternative Therapy","practitioners":[{"id":"73ae3acb-fc2a-40b3-8d0b-93c1c6c25271","name":"808 Bodyworx","image":"https://img1.wsimg.com/isteam/ip/36fe7e49-c245-4e51-b39a-17e47cb66407/logo-horizontal-transparent.png","type":"practitioner","modality":"Massage, Alternative Therapy","modalities":["Massage","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"I'll help you achieve your performance goals with my customizable pain relief services.","location":"Hilo","rating":5,"lat":19.722841,"lng":-155.089682,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"d6018adb-5e27-4636-9eec-10b822940c82","name":"Alex Rose","businessName":"Alex Rose Coaching LLC","image":"https://static.wixstatic.com/media/9f1b68_2ed699a348c7464b9836ea8d7589e24c~mv2.jpg/v1/fill/w_147,h_210,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/9f1b68_2ed699a348c7464b9836ea8d7589e24c~mv2.jpg","type":"practitioner","modality":"Life Coaching, Alternative Therapy","modalities":["Life Coaching","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"I design paths that help people build clarity and meaning in their lives. Through ceremonies, rites of passage, and rituals, I create experiences that anchor people in purpose and guide them toward living with intention.","location":"Waimea","rating":5,"lat":20.023737,"lng":-155.676644,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"bd9d29fe-8c1b-4d2b-b8e1-9e771ee16313","name":"Kipaipai Counseling","businessName":"Kipaipai Counseling","image":"https://www.kipaipaicounseling.com/client-portal-api/practice-website-uploads/250804","type":"practitioner","modality":"Counseling, Alternative Therapy","modalities":["Counseling","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"LGBTQ+ and gender affirmative mental health counseling in Keaau, Hawaii, offering Telehealth appointments. As a Queer Counselor, Alex Stitt founded Kīpaipai Counseling to provide a safe space for lesbian, gay, bisexual, transgender, and nonbinary people to explore and empower their identity.","location":"Keaau","rating":5,"lat":19.589513,"lng":-154.939848,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"dd610c60-7c0c-4852-99e4-9c481fb82fef","name":"Angela Mulligan","image":"http://static1.squarespace.com/static/574d9c99356fb0bb346426ed/t/68081a72f9128f276c4d285b/1745361522770/IMG_5835.jpg?format=1500w","type":"practitioner","modality":"Psychotherapy, Trauma-Informed Care, Alternative Therapy","modalities":["Psychotherapy","Trauma-Informed Care","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Marriage and Family Therapist offering Emotionally Focused Therapy (EFT) for couples and families, Internal Family Systems (IFS) therapy for individuals and EMDR for people healing from trauma in Hawaii and Colorado. Specializing in LGBTQ+ couples, trauma and attachment healing.","location":"Hawi","rating":5,"lat":20.237111,"lng":-155.832114,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"4df13663-e93d-40a5-bbe1-cc3a2fe7352f","name":"Supporting Your Well-Being","businessName":"Big Island Hypnosis","image":"https://img1.wsimg.com/isteam/stock/Zz7dO4D","type":"practitioner","modality":"Psychotherapy, Hypnotherapy, Alternative Therapy","modalities":["Psychotherapy","Hypnotherapy","Alternative Therapy"],"sessionType":"in_person","acceptsNewClients":true,"bio":"helping you to be your best self","location":"Kona","rating":5,"lat":19.610499,"lng":-155.973485,"tier":"free","externalBookingUrl":"","isl