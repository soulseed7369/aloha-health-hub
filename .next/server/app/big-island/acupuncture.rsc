14:["$","$L15",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"acupuncture","modalityName":"Acupuncture","practitioners":[{"id":"ba9623c3-4612-4204-b035-68d1605a8f76","name":"Aaron Ishigo - Big Island Acupunture","title":"$undefined","businessName":"Big Island Acupunture","image":"https://www.bigislandacu.com/resources/Rustic%20Minimal%20Wedding%20Print%20Banner.png.opt798x399o0%2C0s798x399.png","type":"practitioner","modality":"Acupuncture, Herbalism, Functional Medicine","modalities":["Acupuncture","Herbalism","Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Located at 82 Keaʻa Street in beautiful Hilo, Hawaii, Big Island Acupuncture is honored to have been recognized as East Hawaii's Best Acupuncture for three consecutive years 2023, 2024 and 2025. Mahalo to our community for your continued trust and support!","location":"Hilo","rating":5,"lat":19.723955,"lng":-155.05891,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"f33c481f-daa0-4ac3-a61e-0ba1860b6607","name":"Adam Moes","title":"$undefined","businessName":"$undefined","image":"https://acuadam.com/wp/wp-content/themes/twentyeleven/images/headers/hanoi.jpg","type":"practitioner","modality":"Acupuncture","modalities":["Acupuncture"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Acupuncture and Herbs, The Kau Clinic of Adam Moes L.Ac.","location":"Naalehu","rating":5,"lat":19.045319,"lng":-155.623931,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"4b3100e5-b2c5-4fc6-97e4-6eb19865f51c","name":"Natural Balance","title":"$undefined","businessName":"Natural Balance","image":"https://naturalbalancehawaii.com/wp-content/uploads/2026/02/20251202_142428.jpg","type":"practitioner","modality":"Acupuncture, Massage","modalities":["Acupuncture","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Educated, experienced and effective practitioners in a family run alternative medicine clinic.","location":"Pahala","rating":5,"lat":19.276218,"lng":-155.474947,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"8a8ef3f4-12cd-454a-ab3a-f9e731aaf11c","name":"HAWAII ISLAND ACUPUNCTURE IN NA'ALEHU","title":"$undefined","businessName":"HAWAII ISLAND ACUPUNCTURE","image":"https://www.hawaiiislandacupuncture.com/uploads/2/3/9/4/23947285/published/img-5702.jpg?1694223227","type":"practitioner","modality":"Acupuncture, Massage","modalities":["Acupuncture","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Acupuncture Hawaii, Naalehu, chinese acupuncture, herbal medicine, chinese herbal medicine, cupping, acupuncture treatment, Chinese medicine, acupuncturist, acupuncturist,  herbs, healing, massage, shiatsu","location":"Naalehu","rating":5,"lat":19.0433,"lng":-155.614479,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"5e68d553-2791-476f-bce1-4588f4ab89b1","name":"April Johnston","title":"$undefined","businessName":"The Body Shop Acupuncture","image":"","type":"practitioner","modality":"Acupuncture","modalities":["Acupuncture"],"sessionType":"in_person","acceptsNewClients":true,"bio":"r. April Johnston help patients move along their journey towards wellness using Traditional Chinese Medicine (TCM).  This encompasses tools such as acupuncture, herbal medicine, dietary therapy, cupping, moxibustion and guasha.  She also utilize more modern tools such as electro-acupuncture, ultrasound, phototherapy, infrared lasers and kinesio-taping where appropriate. Dr Johnston believes in an integrated team approach between western and eastern medicines to best help her patients. Dr Johnston regularly interfaces with other medical providers to help her patients.","location":"Kailua-Kona","rating":5,"lat":19.64,"lng":-155.9969,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"ac844d94-a144-43d6-b328-11ce0d96165d","name":"Becky Jacobs, DACM, DCa.","title":"$undefined","businessName":"$undefined","image":"https://www.seitaishinpoacupuncture.com/wp-content/uploads/2010/01/seitai-shinpo-group-2012.jpg","type":"practitioner","modality":"Acupuncture","modalities":["Acupuncture"],"sessionType":"in_person","acceptsNewClients":true,"bio":"The following practitioners are recognized by the Seitai Shinpo Acupuncture Foundation as Certified Seitai Shinpo Acupuncturists:","location":"Waimea","rating":5,"lat":20.070426,"lng":-155.853628,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"893d0217-81b6-401c-9f3c-3fb600ad5b69","name":"Abundant Health Acupuncture Cassandra Cupples","title":"$undefined","businessName":"Abundant Health Acupuncture","image":"https://s3.amazonaws.com/storage.qisites.com/uploads/aha808.com/images/1590728626-yin_yang_brown_rosette.jpg","type":"practitioner","modality":"Acupuncture","modalities":["Acupuncture"],"sessionType":"in_person","acceptsNewClients":true,"bio":"At Abundant Health Acupuncture the goal is to help you achieve  optimum health and wellness . Having evolved over thousands of years, acupuncture is one of the oldest continually practiced medical modalities in the world. Acupuncture is used to prevent and treat disease, relieve pain, balance mood, enhance athletic performance, increase fertility, and improve overall health and wellness.","location":"Naalehu","rating":5,"lat":19.046118,"lng":-155.660123,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"965a0240-25f9-42cc-96e6-368bd44cd928","name":"Charley Somsanguansit","title":"$undefined","businessName":"Rooted Fire Wellness LLC","image":"https://static.wixstatic.com/media/2eb9f3_66a4496259064676b1819f8b5a782d43~mv2.png/v1/fill/w_49,h_29,al_c,q_85,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/2eb9f3_66a4496259064676b1819f8b5a782d43~mv2.png","type":"practitioner","modality":"Acupuncture, Massage","modalities":["Acupuncture","Massage"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Rooted Fire Wellness LLC located in Kailua Kona, Hawaii offers acupuncture and massage. Specializing in Seitai Shinpo Japanese Structural Acupuncture. Experience full body and mind relaxation.","location":"Kailua-Kona","rating":5,"lat":19.626512,"lng":-155.986455,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"6602f5b2-a2be-40fe-8110-3a6ba1a0022b","name":"Dale Eka","title":"$undefined","businessName":"Puna Acupuncture and Natural Healing","image":"https://punaacupuncture.wordpress.com/wp-content/uploads/2015/08/screen-shot-2015-08-18-at-5-18-32-pm.png","type":"practitioner","modality":"Acupuncture","modalities":["Acupuncture"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Nutrition therapy, Intuitive massage, Angel energy healing","location":"Pāhoa","rating":5,"lat":19.531464,"lng":-154.914379,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"a9ecd5d5-9551-4918-b91f-7b7d580d5262","name":"Frequently Asked Questions","title":"$undefined","businessName":"Inspire Wellness","image":"https://inspire-wellness.net/wp-content/uploads/2021/01/logo200.png","type":"practitioner","modality":"Acupuncture, Naturopathic","modalities":["Acupuncture","Naturopathic"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Combining natural medicine & traditional healing methods with the best of modern science.","location":"Kailua-Kona","rating":5,"lat":19.638605,"lng":-155.988656,"tier":"free","externalBookingUrl":"","island":"big_island","upda