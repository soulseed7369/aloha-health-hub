_2,enc_avif,quality_auto/0446d4_e79627d0541743fb994095149fa405e7~mv2_d_5038_3072_s_4_2.jpg","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Hi, I’m Justyn — a Doctor of Acupuncture and Chinese Medicine. I help you cultivate whole-system harmony, vitality, and radiant wellbeing from the inside out.","location":"Kailua-Kona","rating":5,"lat":19.694042,"lng":-155.970494,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"60a5a7f1-4700-4000-b439-4487abd396a6","name":"Krista Graves - Ola Acupunture","title":"$undefined","businessName":"Ola Acupunture","image":"https://static.wixstatic.com/media/a406f6_b6f098e42566418580060d7c56e71f06~mv2.jpg/v1/crop/x_0,y_585,w_3687,h_4359/fill/w_406,h_480,al_c,q_80,usm_0.66_1.00_0.01,enc_avif,quality_auto/zOla_WaitingArea_104.jpg","type":"practitioner","modality":"Acupuncture, Nervous System Regulation","modalities":["Acupuncture","Nervous System Regulation"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Ola Acupuncture, Art & Human Design at the Studio in Honokaa","location":"Honokaa","rating":5,"lat":20.079231,"lng":-155.469392,"tier":"free","externalBookingUrl":"$undefined","island":"big_island","updatedAt":"2026-04-02T09:57:41.320754+00:00","verified":false},{"id":"dbef94cf-ddb9-4eae-86d9-76b1b03e0f34","name":"Kristen McCormack","title":"$undefined","businessName":"Golden Flower Healing Arts","image":"http://static1.squarespace.com/static/661dc14e8de0ce6f79ccf33c/t/661f894cd292cd3473d5ad18/1713342796355/kristen-goldenflowerlogo6.png?format=1500w","type":"practitioner","modality":"Acupuncture, Art Therapy, Life Coaching, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","Art Therapy","Life Coaching","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Explore holistic principles of healing and ancient practices of body mind spirit wellness. Group or private mentorships offered  in Chinese medicine, meridian bodywork, phenomenal touch massage, nutrition, mindfulness, qigong and animistic practices.","location":"Pāhoa","rating":5,"lat":19.497503,"lng":-154.95081,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"3a432478-ff09-489b-a0ba-de8f0b29c782","name":"Laura A. Powers","title":"$undefined","businessName":"$undefined","image":"","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"My goal is to get you on the least amount of supplements and medications necessary.  Traditional Chinese Medicine (TCM) uses dietary and lifestyle changes along with Acupuncture and Herbs to bring you to an optimum state of health.  TCM changed my life. I was the person that got sick when a bug first circulated the community and then again after everyone else had it.  I was always sick, but that changed once I treated myself to regular acupuncture treatments.  I received a course of facial rejuvenation acupuncture (ten treatments once a week), which also works on improving your overall health.  Once the course was completed, not only did I look younger and fresher, I rarely ever got sick again.  (And the effects have lasted years.)  Acupuncture is a very important part of my health routine!","location":"Hilo","rating":5,"lat":19.725014,"lng":-155.087186,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T21:00:57.532225+00:00","verified":false},{"id":"6c13c86d-414c-4a89-98d7-540566c6e026","name":"Lauran Chapple","title":"$undefined","businessName":"Oceanic Wellness","image":"https://static.wixstatic.com/media/84770f_6efb5a8a5b454f79b93f4e5cfd701fccf000.jpg/v1/fill/w_288,h_105,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/84770f_6efb5a8a5b454f79b93f4e5cfd701fccf000.jpg","type":"practitioner","modality":"Acupuncture, Herbalism","modalities":["Acupuncture","Herbalism"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Acupuncture is the placement of tiny needles along meridians or trigger points to stimulate the body's own natural healing abilities. Acupuncture treatments may also include moxibustion, cupping, massage, essential oils, e-stim, magnets ear seeds or tacks. Acupuncture can be helpful for relieving pain, reducing stress and providing relief from a wide variety of symptoms.","location":"Waimea","rating":5,"lat":19.932919,"lng":-155.792483,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"1af16f43-4c5c-4f16-a91b-34ce27850b46","name":"Lori Campbell","title":"$undefined","businessName":"$undefined","image":"","type":"practitioner","modality":"Acupuncture","modalities":["Acupuncture"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Lori Campbell provides world-class acupuncture in Keaau HI. Call and start improving your health today: (808) 640-8923","location":"Keaau","rating":5,"lat":19.545293,"lng":-154.991076,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"91fbd113-9a2f-4556-92f3-8a09ba0f7e5f","name":"Mei-jen Stokesbary","title":"$undefined","businessName":"$undefined","image":"","type":"practitioner","modality":"Acupuncture, Herbalism","modalities":["Acupuncture","Herbalism"],"sessionType":"in_person","acceptsNewClients":true,"bio":"","location":"Waimea","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T20:18:10.862484+00:00","verified":false},{"id":"936ec842-a311-460b-8302-6ef8e0ba8e47","name":"Mei-jen Sun Stokesbary, L.Ac.","title":"$undefined","busin