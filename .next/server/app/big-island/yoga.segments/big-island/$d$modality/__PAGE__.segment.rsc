3:["$","$L6",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"yoga","modalityName":"Yoga","practitioners":[{"id":"fc5093bb-88c6-4bb8-90c0-ac0fd2a90d1e","name":"Ashley Mai Demaline","image":"https://static.wixstatic.com/media/11062b_95d34f15761e4114a57b17823228948ef000.jpg/v1/fill/w_288,h_162,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/11062b_95d34f15761e4114a57b17823228948ef000.jpg","type":"practitioner","modality":"Functional Medicine, Yoga","modalities":["Functional Medicine","Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Offering functional medicine, ayurvedic and medical marijuana consultations.","location":"Holualoa","rating":5,"lat":19.619758,"lng":-155.949169,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-04T05:20:02.625318+00:00","verified":false},{"id":"fa251802-cb4a-42c5-ae83-86c73caedbf5","name":"Calley O’Neill","businessName":"The Full Body Elixir ","image":"http://www.calleyoneillyoga.com/SAM_1475.jpg","type":"practitioner","modality":"Yoga","modalities":["Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Calley O'Neill teaches yoga on the beach every Tues and Thurs from 8 to 9:30 am, and Sat from 8:30 to 10 am at Lava Lava Beach Club, Waikoloa Beach","location":"Waikoloa","rating":5,"lat":19.912811,"lng":-155.887255,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"8ff1717b-35e5-472b-8359-4b93eddaf033","name":"FitByWhitt Hawaii","businessName":"FitByWhitt Hawaii","image":"https://img1.wsimg.com/isteam/ip/df4dfb39-8aab-4824-9d30-3e7e65a551ee/Untitled%20design%20(1).png","type":"practitioner","modality":"Yoga","modalities":["Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"At FitbyWhitt, I believe fitness should be accessible to everyone. My mission is to keep fitness affordable + provide quality training and education to everyone who walks through these doors. My motto is \"I'm not Exclusive...I'm INCLUSIVE\" Every woman is welcome here regardless of age, fitness level or budget! Come Werk with us!","location":"Keaau","rating":5,"lat":19.635918,"lng":-155.045949,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"af8f72f6-1611-4f4e-9080-f0fc0ce1d530","name":"Gloria  Baraquio","image":"http://static1.squarespace.com/static/53d82867e4b0d4d3dfed83e3/t/68b53cef249f594a002cba21/1757002433699/FUJI0973.webp?format=1500w","type":"practitioner","modality":"Yoga, Meditation, Counseling, Life Coaching","modalities":["Yoga","Meditation","Counseling","Life Coaching"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Discover Shivakali Yoga with Gloria, offering personalized yoga retreats, teacher training, and spiritual counseling to help you find clarity, peace, and purpose in your life’s journey.","location":"Pahoa","rating":5,"lat":19.526165,"lng":-154.98475,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:57:42.071957+00:00","verified":false},{"id":"c85f0fc9-5103-4747-a76f-56065357fc64","name":"Jackie Orsa","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/fde082bd3e3c74f5b5d18698f4150534.jpg","type":"practitioner","modality":"Breathwork, Yoga, Nervous System Regulation","modalities":["Breathwork","Yoga","Nervous System Regulation"],"sessionType":"in_person","acceptsNewClients":true,"bio":"As a certified yoga teacher and a yoga therapist in training, I work with individuals and small groups, both in person and virtually, offering supportive, personalized practices for those navigating symptoms of stress, anxiety, and overwhelm.","location":"Holualoa","rating":5,"lat":0,"lng":0,"tier":"free","island":"big_island","updatedAt":"2026-04-02T09:57:40.532049+00:00","verified":false},{"id":"7a54da69-04a2-4dee-9585-ea6417d04fa3","name":"Jamie Belmarez","businessName":"Jamie Eversweet Belmarez","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/practitioners/1773111631184-yk06pl6zcnq.png","type":"practitioner","modality":"Massage, Yoga","modalities":["Massage","Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Jamie Eversweet Belmarez is a licensed massage therapist and certified yoga teacher working in the field since 2001.\n\nHer passion for massage and bodywork began as a young child, learning from her mother about the power of healing touch.\n\nJamie’s massage style is a balance of eastern and western with education in and experience including Thai Yoga massage, Shiatsu, Reiki, Tui Na and cupping as well as western modalities such as trigger point therapy, connective tissue release techniques, compassionate inquiry, deep tissue therapy, kinesiology, neuromuscular facilitation and more.\n\nJamie likes to attend to the source of imbalances rather than \"chase the pain\" or \"fix\" people. She has a dynamic practice and is committed to working with you to release and balance.","location":"Kapaau","rating":5,"lat":20.230819,"lng":-155.799408,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"a9405395-5d48-46b4-bed8-b1cceea81530","name":"Jessica Sevapreet Hesser","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/e326419c642b33a416cfa5d6ba772910.jpg","type":"practitioner","modality":"Yoga","modalities":["Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"YogaCabana.com page for Jessica Sevapreet Hesser, a Pahoa, HI yoga instructor.","location":"Pahoa","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"b74db721-6fb2-496c-8857-ef67bf9e5075","name":"Joanie Collins ","businessName":"Mālameleola Music and Pilates","image":"https://static.wixstatic.com/media/59d738_2c76aa1178f446b18009ac54d0a5142d%7Emv2.png/v1/fit/w_2500,h_1330,al_c/59d738_2c76aa1178f446b18009ac54d0a5142d%7Emv2.png","type":"practitioner","modality":"Yoga, Fitness","modalities":["Yoga","Fitness"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Joanie Collins is a musician who plays violin and ukulele.  She teaches pilates and performs Hawaiian Wedding Ceremonies.","location":"Hawi","rating":5,"lat":20.238282,"lng":-155.830547,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:57:41.95447+00:00","verified":false},{"id":"d3b7035f-adc4-4dfa-a729-b097d1dfba3c","name":"Lisa Marinho","businessName":"Body Vitality","image":"https://static1.squarespace.com/static/58990a66f7e0abb25ad81074/t/65dcdd7a4b1d015ccc970513/1772780851310/","type":"practitioner","modality":"Yoga, Reiki","modalities":["Yoga","Reiki"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Body Vitality offers yoga, meditation, Reiki, hypnosis, wellness coaching, and retreats in Hawaii and online. Restore balance, energy, and well-being for body and mind.","location":"Hawi","rating":5,"lat":20.237111,"lng":-155.832114,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"903a2e68-2ce1-413f-a912-bc8fe73c6739","name":"Maya Parish","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/avatars/1772148918998_0wn0ypd78jos.webp","type":"practitioner","modality":"Life Coaching, Yoga","modalities":["Life Coaching","Yoga"],"sessionType":"in_person","acceptsNewClients":true,"bio":"At this time, I am mostly offering private sessions to individuals & groups at their vacation rentals, private homes and hotels. ","location":"Hawi","rating":5,"lat":19.64,"lng":-155.9969,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"8b3b475b-277d-405e-a450-e2a6bf96e14d","name":"Radhe Hendrickson","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/1959462e8165144883d6223b0cda8b67.jpg","type":"practitioner","modality":"Yoga, Meditation","modalities":["Yoga","Meditation"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Radhe first practiced yoga as a freshman in college upon the recommendation of her father. She was classically trained in ballet as a child so it was an easy transition for her to make. From 2010 to 2017 she lived and worked in ashrams, both in Hawaii and in Colorado. After receiving her E-RYT 500 and advanced yoga teaching certification, she led numerous Hatha Yoga Teacher Trainings. Radhe’s Masters in Holistic Health laid the foundation for her private consultations in yoga, focusing on wellness and an introduction to Ayerveda. She is also a certified meditation teacher.","location":"Holualoa","rating":5,"lat":0,"lng":0,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[{"id":"6ab46f74-df28-44ca-85e1-3643c901ee31","name":"Ahu Lani Sanctuary","image":"http://static1.squarespace.com/static/59f766a3d74cff20ceed67e2/t/59f7713364265f16160dea86/1509388600254/spiral-logo.png?format=1500w","modality":"Yoga, Nature Therapy","modalities":["Yoga","Nature Therapy"],"location":"Paauhau","rating":5,"lat":20.013804,"lng":-155.441775,"services":[],"tier":"free","description":"Big Island Hawaii Yoga Retreat Center and Education Facility","centerType":"retreat_center","centerTypeLabel":"Retreat Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"2353b254-831b-45ab-9925-7c9c7f2a9074","name":"Alea Lani Massage and Yoga","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1775085925565-kv7b56t912l.webp","modality":"Massage, Yoga, Breathwork, Energy Healing, Fitness","modalities":["Massage","Yoga","Breathwork","Energy Healing","Fitness"],"location":"Waimea","rating":5,"lat":19.941438,"lng":-155.858294,"services":[],"tier":"free","description":"Alea Lani Massage & Yoga offers personalized massage therapy and mindful yoga practices. We help every body feel good!  Explore more.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1775085925565-kv7b56t912l.webp"],"workingHours":{"fri":null,"mon":null,"sat":null,"sun":null,"thu":null,"tue":null,"wed":null},"acceptsNewClients":true,"verified":true},{"id":"f0f94aca-099a-461b-b9bf-6b33604908b1","name":"Aloha Wellness Center","image":"https://www.hawaiinaturopathicretreat.com/wp-content/uploads/2018/11/detox-retreat-hawaii-10-days.png","modality":"Yoga","modalities":["Yoga"],"location":"Hilo","rating":5,"lat":19.722139,"lng":-155.090002,"services":[],"tier":"free","description":"Hawaii Naturopathic Retreat is a Holistic Detox Retreat Center in Hawaii & Hilo Offering Medically Supervised Detoxification & Natural Drug Rehabilitation.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"40ccdddd-752c-4886-a782-ae2158e0f351","name":"Balancing Monkey Yoga","image":"http://static1.squarespace.com/static/554d1c7ce4b0134fb5962ad4/t/554d1d96e4b04c60280ea302/1431117208393/BMY_Monkey_RGB.png?format=1500w","modality":"Yoga","modalities":["Yoga"],"location":"Hilo","rating":5,"lat":19.738094,"lng":-155.039599,"services":[],"tier":"free","description":"Balancing Monkey Yoga is a yoga studio that values collaboration.   We serve the community through high quality, affordable, accessible classes rooted in yogic philosophy and a love of 