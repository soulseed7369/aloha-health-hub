3:["$","$L6",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"tcm","modalityName":"TCM (Traditional Chinese Medicine)","practitioners":[{"id":"cdce337b-68fb-483b-9230-6731f1d4092e","name":"Eugene Abraham","image":"https://hilobayacupuncture.com/wp-content/uploads/elementor/thumbs/Acupuncture-pmftbx7dws6bm1fufto5c347i1pl6p8tedugtbr7g0.jpg","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Resolve Pain Improve Sleep Enhance Well-Being Book Appointment (808) 933-1300 Welcome! Hilo Bay Acupuncture is an acupuncture and Chinese Medicine Clinic located in downtown Hilo, HI. It is our mission to provide compassionate, professional, and effective care to every patient. We will work with you treat your body, mind and spirit and deliver safe and […]","location":"Hilo","rating":5,"lat":19.726007,"lng":-155.088229,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"c902f6ee-c85f-4f18-bec5-6460fa17e522","name":"Justyn Bonomi","businessName":"Shen Hale Wellness","image":"https://static.wixstatic.com/media/0446d4_e79627d0541743fb994095149fa405e7~mv2_d_5038_3072_s_4_2.jpg/v1/fill/w_123,h_75,al_c,q_80,usm_0.66_1.00_0.01,blur_2,enc_avif,quality_auto/0446d4_e79627d0541743fb994095149fa405e7~mv2_d_5038_3072_s_4_2.jpg","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Hi, I’m Justyn — a Doctor of Acupuncture and Chinese Medicine. I help you cultivate whole-system harmony, vitality, and radiant wellbeing from the inside out.","location":"Kailua-Kona","rating":5,"lat":19.694042,"lng":-155.970494,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"dbef94cf-ddb9-4eae-86d9-76b1b03e0f34","name":"Kristen McCormack","businessName":"Golden Flower Healing Arts","image":"http://static1.squarespace.com/static/661dc14e8de0ce6f79ccf33c/t/661f894cd292cd3473d5ad18/1713342796355/kristen-goldenflowerlogo6.png?format=1500w","type":"practitioner","modality":"Acupuncture, Art Therapy, Life Coaching, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","Art Therapy","Life Coaching","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Explore holistic principles of healing and ancient practices of body mind spirit wellness. Group or private mentorships offered  in Chinese medicine, meridian bodywork, phenomenal touch massage, nutrition, mindfulness, qigong and animistic practices.","location":"Pāhoa","rating":5,"lat":19.497503,"lng":-154.95081,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"3a432478-ff09-489b-a0ba-de8f0b29c782","name":"Laura A. Powers","image":"","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"My goal is to get you on the least amount of supplements and medications necessary.  Traditional Chinese Medicine (TCM) uses dietary and lifestyle changes along with Acupuncture and Herbs to bring you to an optimum state of health.  TCM changed my life. I was the person that got sick when a bug first circulated the community and then again after everyone else had it.  I was always sick, but that changed once I treated myself to regular acupuncture treatments.  I received a course of facial rejuvenation acupuncture (ten treatments once a week), which also works on improving your overall health.  Once the course was completed, not only did I look younger and fresher, I rarely ever got sick again.  (And the effects have lasted years.)  Acupuncture is a very important part of my health routine!","location":"Hilo","rating":5,"lat":19.725014,"lng":-155.087186,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T21:00:57.532225+00:00","verified":false},{"id":"936ec842-a311-460b-8302-6ef8e0ba8e47","name":"Mei-jen Sun Stokesbary, L.Ac.","image":"https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/practitioners/1773111615274-dxf6c2rx2x.jpg","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine), Herbalism","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)","Herbalism"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Mei-jen Sun Stokesbary, L.Ac. is a licensed acupuncturist on the Big Island of Hawaii. She provides Oriental Medicine consultations, structural alignment exams and treatments of musculoskeletal disharmonies. She provides diet & nutritional counseling to help balance your system. She comes from a long line of doctors, surgeons, and healers.","location":"Waimea","rating":5,"lat":20.082276,"lng":-155.83368,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"49a5bec9-8cf7-4d7b-afcb-b410a8868273","name":"Micah Brewer","businessName":"Balanced Life Acupuncture & Massage Services","image":"https://www.Balancedlifehilo.com/uploads/1/3/0/4/13040631/published/webpic.jpg?1651994672","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)"],"sessionType":"in_person","acceptsNewClients":true,"bio":"This is a holistic healing center located in downtown Hilo, in Wailoa Plaza. I offering an integrated approach to helping you on the road to a balanced, healthy self.\n\nMy goal as healer is to use all my knowledge to create an integrated and holistic approach to your specific health needs and healing process  with experience in a variety of modalities that I use to tailor to each person and their individual needs .  ","location":"Hilo","rating":5,"lat":19.714553,"lng":-155.074089,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false},{"id":"58bbc01e-8a8b-42a7-b879-436bcb7577de","name":"Unity Nguyen MD LAc","businessName":"Dr. Unity Regenerative Health","image":"http://static1.squarespace.com/static/63ab82a9d5e53d3276cf10db/t/63c4a7a426955104853063e8/1673832356973/Logo+and+tagline+horizontal.png?format=1500w","type":"practitioner","modality":"Acupuncture, TCM (Traditional Chinese Medicine), Functional Medicine","modalities":["Acupuncture","TCM (Traditional Chinese Medicine)","Functional Medicine"],"sessionType":"in_person","acceptsNewClients":true,"bio":"“Fatigue, fibromyalgia, anxiety, and a lot of stomach problems. I used to think I would be sick half the time for the rest of my life.  It’s like a miracle, the way her system works.  Even my skin got so nice, the wrinkles and bumps on my face are smaller.”","location":"Keaau","rating":5,"lat":19.600849,"lng":-154.946123,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[{"id":"db8606c1-5a61-4760-926e-eaea68b2746d","name":"Cherry Healing Center","image":"https://cherryhealingcenter.com/wp-content/uploads/2026/01/Cherry-Healing-Center_-Web-Banner.png","modality":"Acupuncture, Massage, Nature Therapy, TCM (Traditional Chinese Medicine)","modalities":["Acupuncture","Massage","Nature Therapy","TCM (Traditional Chinese Medicine)"],"location":"Hilo","rating":5,"lat":19.72498,"lng":-155.089869,"services":[],"tier":"free","description":"This is why we utilize a variety of therapeutic modalities such as acupuncture, massage, simple structural guidance, herbal formulas, and access to fresh nutritional foods to stimulate your body’s inherent ability to repair and restore vitality. ","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"87bb430e-c2b6-473d-bf3b-7e0927dd4df3","name":"Hawaii Holistic Care","image":"https://lirp.cdn-website.com/2464e81b/dms3rep/multi/opt/social-image-1920w.png","modality":"Functional Medicine, Longevity, IV Therapy, TCM (Traditional Chinese Medicine), Acupuncture, Trauma-Informed Care, Somatic Therapy","modalities":["Functional Medicine","Longevity","IV Therapy","TCM (Traditional Chinese Medicine)","Acupuncture","Trauma-Informed Care","Somatic Therapy"],"location":"Kailua-Kona","rating":5,"lat":19.626512,"lng":-155.986455,"services":[],"tier":"free","description":"Whole-person healing with acupuncture, functional medicine & soul care. Community clinic & wellness center in Kailua-Kona. Insurance accepted.","centerType":"wellness_center","centerTypeLabel":"Wellness Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true},{"id":"20fb11ba-9704-45d7-876f-a49af0ac5c90","name":"The Koa Clinic","image":"https://static.wixstatic.com/media/a3026b_fd7a53126e444dc7bd2799b210d800f4~mv2.jpg/v1/fill/w_1200,h_630,al_c/a3026b_fd7a53126e444dc7bd2799b210d800f4~mv2.jpg","modality":"Naturopathic, Functional Medicine, TCM (Traditional Chinese Medicine)","modalities":["Naturopathic","Functional Medicine","TCM (Traditional Chinese Medicine)"],"location":"Kailua-Kona","rating":5,"lat":19.626844,"lng":-155.981072,"services":[],"tier":"free","description":"Integrative primary health care & more in Kailua-Kona, Hawaii at The Koa Clinic. Our experienced team offers naturopathic, functional, and Traditional Chinese Medicine services, plus holistic wellness solutions for optimal health. Experience personalized, compassionate care in Kona today.","centerType":"clinic","centerTypeLabel":"Clinic","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":[],"workingHours":{},"acceptsNewClients":true,"verified":true}],"totalPractitioners":7,"totalCenters":3,"citiesServed":["Hilo","Kailua-Kona","Keaau","Pāhoa","Waimea"]}]
