7:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"ItemList\",\"name\":\"Family Constellation Practitioners and Centers on Big Island\",\"description\":\"Directory of Family Constellation practitioners and wellness centers on Big Island\",\"url\":\"https://hawaiiwellness.net/big-island/family-constellation\",\"numberOfItems\":1,\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"item\":{\"@type\":\"LocalBusiness\",\"name\":\"Tomi Knutson\",\"image\":\"https://www.tomiknutson.com/uploads/2/3/3/9/2339187/published/img-8123.jpeg?1745054030\",\"url\":\"https://hawaiiwellness.net/profile/fd772e97-a9c1-4e2e-ad5a-1fa9f2da378c\",\"address\":{\"@type\":\"PostalAddress\",\"addressRegion\":\"BIG ISLAND\",\"addressCountry\":\"US\"}}}]}"}}],["$","$L13",null,{"islandSlug":"big-island","islandDisplayName":"Big Island","modalitySlug":"family-constellation","modalityName":"Family Constellation","practitioners":[{"id":"fd772e97-a9c1-4e2e-ad5a-1fa9f2da378c","name":"Tomi Knutson","title":"$undefined","businessName":"$undefined","image":"https://www.tomiknutson.com/uploads/2/3/3/9/2339187/published/img-8123.jpeg?1745054030","type":"practitioner","modality":"Craniosacral, Massage, Family Constellation","modalities":["Craniosacral","Massage","Family Constellation"],"sessionType":"in_person","acceptsNewClients":true,"bio":"Hello, my name is Tomi Knutson and I am an LMT and Integrative practitioner specializing in Adult and Pediatric Craniosacral Therapy, Manual Lymph Drainage, and Family Constellation Work. In 2021, a long-held dream of mine came true when I moved to the Big Island of Hawaii from Oakland, CA. I now practice here in Kailua-Kona, as well as, visit my Oakland office twice a year.","location":"Kailua-Kona","rating":5,"lat":19.626935,"lng":-155.981899,"tier":"free","externalBookingUrl":"","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","verified":false}],"centers":[],"totalPractitioners":1,"totalCenters":0,"citiesServed":["Kailua-Kona"]}]]
