":5,"lat":19.518149,"lng":-155.920678,"services":[],"tier":"free","description":"Muaisa Hale Pule's principal aim is its spiritually-focused programs, sessions and retreats. Whether you're kama'aima (an island resident) or you're visiting from off-island, we offer donor-funded guidance, direction, retreats, vision quests, and natural healing venues to support inner needs and assist with spiritual housekeeping.\n\n* * * * * 5.0\n\"My husband and i got all we needed and more. ZZ and Jack are absolutely the BEST. Their expertise spans far greater than you can imagine.\" \n--DM, 2022","centerType":"retreat_center","centerTypeLabel":"Retreat Center","island":"big_island","updatedAt":"2026-04-02T09:31:30.328449+00:00","photos":["https://sccksxvjckllxlvyuotv.supabase.co/storage/v1/object/public/practitioner-images/centers/1774581196622-4yd8ujey4tx.webp"],"bio":"$undefined","workingHours":{"fri":null,"mon":null,"sat":null,"sun":null,"thu":null,"tue":null,"wed":null},"acceptsNewClients":true,"verified":true}],"totalPractitioners":2,"totalCenters":1,"citiesServed":["Captain Cook","Pāhoa","Waimea"]}]]
