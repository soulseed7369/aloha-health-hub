{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/maui/layout,_N_T_/maui/[modality]/layout,_N_T_/maui/[modality]/page,_N_T_/maui/lomilomi"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/maui/$d$modality/__PAGE__",
    "/maui/$d$modality",
    "/maui",
    "/_index",
    "/_head"
  ]
}