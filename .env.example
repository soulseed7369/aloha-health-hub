# Copy this file to .env.local and fill in your values.
# Never commit .env or .env.local to git — they contain secrets!

# ── Supabase (Client-side only) ────────────────────────────────────────────────
# IMPORTANT: Only VITE_ prefixed variables are exposed to the browser.
# Service role key must NEVER be in VITE_* variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ── Supabase (Server-side / Edge Functions only) ────────────────────────────────
# These are ONLY for Supabase Edge Functions (not prefixed with VITE_).
# They will NOT be exposed to the browser bundle.
# Set these via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # ⚠️ NEVER use VITE_ prefix on this!

# ── Stripe ─────────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...    # publishable key (safe to expose in browser)
STRIPE_SECRET_KEY=sk_live_...              # secret key — Edge Function only, never in browser
STRIPE_WEBHOOK_SECRET=whsec_...            # from Stripe dashboard → Webhooks → signing secret

# ── Optional: Maps & Search APIs ──────────────────────────────────────────────
# GM_API_KEY=your_google_maps_api_key
# BRAVE_API_KEY=your_brave_api_key
